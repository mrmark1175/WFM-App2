# Exordium WFM — environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# The server fails fast at startup if any REQUIRED variable below is missing.
# ---------------------------------------------------------------------------

# ── Required: Database ──────────────────────────────────────────────────────
# Either set DATABASE_URL (preferred), OR set all four PG* variables below.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Alternative to DATABASE_URL — uncomment all four if you use individual vars.
# PGHOST=localhost
# PGUSER=postgres
# PGPASSWORD=
# PGDATABASE=exordium_db

# Optional database tuning.
# PGPORT=5432
# PGSSL=false   # defaults: true when DATABASE_URL is set, false otherwise

# ── Required in production: JWT signing key ─────────────────────────────────
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In non-production the server falls back to an ephemeral random secret
# (sessions are invalidated on every restart).
SESSION_SECRET=

# ── Required when AI assistant is used: at-rest encryption key ──────────────
# Used to AES-256-GCM-encrypt secrets stored in the DB (currently
# ai_settings.api_key). The server fails fast if any code path tries to
# read or write an encrypted secret without this set. Saving an AI key in
# Configuration → AI Assistant or sending a chat message will trigger it.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must decode to exactly 32 bytes (64 hex chars, or 32-byte base64).
KEY_ENCRYPTION_KEY=

# ── Optional: HTTP server ───────────────────────────────────────────────────
# PORT=5000
# NODE_ENV=production

# ── Required by scripts/seed.cjs only (creates the initial super_admin) ─────
# Not read by the running server.
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
# BCRYPT_SALT_ROUNDS=12

# ── Required by scripts/seed_manual_adherence_demo.cjs only ─────────────────
# DEMO_USER_PASSWORD=

# ── Required by server/migrate_to_supabase.cjs only ─────────────────────────
# Source database to read from during the one-shot migration.
# SOURCE_PGHOST=
# SOURCE_PGUSER=
# SOURCE_PGPASSWORD=
# SOURCE_PGDATABASE=
# SOURCE_PGPORT=5432
# SOURCE_PGSSL=false
# Target connection string (any of these is accepted, in priority order):
# TARGET_DATABASE_URL=
# SUPABASE_DB_URL=
# (falls back to DATABASE_URL above)

# ── Optional: Genesys Cloud integration (currently a stub) ──────────────────
# GENESYS_CLIENT_ID=
# GENESYS_CLIENT_SECRET=
# GENESYS_REGION=mypurecloud.com

# ── Optional: frontend API base override ────────────────────────────────────
# Only set when serving the built SPA from a different origin than the API.
# Defaults to relative `/api` paths.
# VITE_API_BASE=
